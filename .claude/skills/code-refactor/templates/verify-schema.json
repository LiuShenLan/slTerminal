{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage Verification Result",
  "description": "单阶段重构的逐项验证结果",
  "type": "object",
  "properties": {
    "allFixed": {
      "type": "boolean",
      "description": "是否所有改动项都已正确修复"
    },
    "failedItems": {
      "type": "array",
      "items": { "type": "string" },
      "description": "未修复的改动项 ID 列表。allFixed 为 true 时为空数组"
    },
    "details": {
      "type": "object",
      "description": "每项的验证结果详情，key 为改动项 ID，value 为包含 status 和 evidence 的对象",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["fixed", "not_fixed", "partial"],
            "description": "修复状态"
          },
          "evidence": {
            "type": "string",
            "description": "验证证据：具体的文件行号或 grep 结果"
          }
        },
        "required": ["status", "evidence"]
      }
    }
  },
  "required": ["allFixed", "failedItems"]
}
